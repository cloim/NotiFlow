<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 디버그 빌드에서 HTTP 웹훅 URL 허용 (개발/테스트용) -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
